{
  "ipc_compat": [
    {
      "name": "schema_payload_without_deep_research",
      "input": {
        "type": "snapshot",
        "payload": {
          "schema_version": 4,
          "transport": {
            "tick": 9
          }
        }
      },
      "expect_has_deep_research": false
    },
    {
      "name": "schema_v2_envelope_with_top_level_deep_research",
      "input": {
        "type": "snapshot",
        "payload": {
          "schema": {
            "schema_version": 4,
            "transport": {
              "tick": 11
            }
          },
          "deep_research": {
            "version": 3,
            "result": {
              "signature": "ok"
            }
          }
        }
      },
      "expect_has_deep_research": true,
      "expected_version": 3
    },
    {
      "name": "legacy_schema_wrapper_with_metadata_sections",
      "input": {
        "type": "snapshot",
        "payload": {
          "schema": {
            "schema_version": 5,
            "transport": {
              "tick": 77,
              "bar": 3,
              "running": true,
              "bpm": 126.0
            }
          },
          "module_health": {
            "status": "degraded",
            "updated_at": 101.5,
            "modules": {
              "clock": {
                "status": "warn"
              }
            }
          },
          "retrospective_capture": {
            "buffer_bars": 8,
            "events_buffered": 155,
            "armed": true,
            "last_commit_path": "captures/last.mid"
          }
        }
      },
      "expect_has_deep_research": false,
      "expected_module_health_status": "degraded",
      "expected_capture_armed": true
    },
    {
      "name": "legacy_wrapper_missing_optional_sections",
      "input": {
        "type": "snapshot",
        "payload": {
          "schema": {
            "schema_version": 5,
            "transport": {
              "tick": 80,
              "bar": 5,
              "running": false,
              "bpm": 110.0
            }
          }
        }
      },
      "expect_has_deep_research": false,
      "expect_missing_optional_sections": [
        "module_health",
        "retrospective_capture",
        "views"
      ]
    },
    {
      "name": "legacy_wrapper_malformed_nested_views_passthrough",
      "input": {
        "type": "snapshot",
        "payload": {
          "schema": {
            "schema_version": 5,
            "transport": {
              "tick": 81,
              "bar": 5,
              "running": true,
              "bpm": 111.0
            },
            "views": "malformed-view-payload"
          }
        }
      },
      "expect_has_deep_research": false,
      "expected_views_type": "str"
    },
    {
      "name": "mixed_legacy_new_envelope_prefers_payload_schema_and_metadata",
      "input": {
        "type": "snapshot",
        "schema_version": 99,
        "transport": {
          "tick": 1,
          "bar": 1,
          "running": false,
          "bpm": 60.0
        },
        "payload": {
          "schema": {
            "schema_version": 5,
            "transport": {
              "tick": 93,
              "bar": 6,
              "running": true,
              "bpm": 133.0
            }
          },
          "deep_research": {
            "version": 8,
            "result": {
              "signature": "mixed"
            }
          },
          "module_health": {
            "status": "ok"
          }
        }
      },
      "expect_has_deep_research": false,
      "expected_tick": 1
    }
  ],
